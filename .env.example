# Railway / production — copy to Railway service variables

DATABASE_URL=
SESSION_SECRET=

NODE_ENV=production
BASE_PATH=/

# GCS object storage (bank transfer slips, public assets)
# Paths use /bucket-name/prefix format
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public
PRIVATE_OBJECT_DIR=/your-bucket/private

# Option A: path to service account JSON file (Railway secret file mount)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Option B: inline JSON (Railway variable — paste minified service account JSON)
# GCS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Expo mobile (build-time) — your Railway public hostname, no https:// prefix
# EXPO_PUBLIC_DOMAIN=your-app.up.railway.app

# ── Production data import (one-time) ───────────────────────────────────────
# Your live DB dump is at lib/db/imports/database_export.sql (outlets, staff, menu, orders).
# On a fresh Railway Postgres, run once (destructive — replaces entire DB):
#   railway run pnpm --filter @workspace/db run import
# After import, disable or remove `releaseCommand` in railway.toml so deploys do not run `db push`.
# Staff PINs in the dump are bcrypt hashes from your existing system (not plain text).
