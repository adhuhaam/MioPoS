# Local development — copy to .env.local and fill in values
# Quick fill from Railway:  bash scripts/pull-env-from-railway.sh

# Railway Postgres public URL (from Postgres service → DATABASE_PUBLIC_URL)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Any long random string for local sessions
SESSION_SECRET=change-me-to-a-long-random-string

NODE_ENV=development
BASE_PATH=/

# API server (Vite proxies /api here)
API_PORT=8787
VITE_PORT=5173

# Optional — GCS for uploads (production / Railway). If unset in development,
# transfer slips are stored under data/local-uploads/ instead.
# PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public
# PRIVATE_OBJECT_DIR=/your-bucket/private
# GCS_SERVICE_ACCOUNT_JSON=
