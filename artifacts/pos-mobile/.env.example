# Production: Railway hostname (no scheme). Used when EXPO_PUBLIC_API_URL is unset.
EXPO_PUBLIC_DOMAIN=your-app.up.railway.app

# Local dev (Mac): point at API from `pnpm dev` (default port 8787)
# Simulator: http://127.0.0.1:8787
# Physical device on same Wi‑Fi: http://YOUR_MAC_LAN_IP:8787
EXPO_PUBLIC_API_URL=http://127.0.0.1:8787
